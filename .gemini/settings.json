{
  "theme": "GitHub",
  "usageStatisticsEnabled": true,
  "checkpointing": {
    "enabled": true
  },
  "mcp": {
    "allowed": [
      "myserver",
      "sqlite_server",
      "playwright",
      "github",
      "powershell",
      "ssh-mcp"
    ],
    "excluded": [
      "experimental-server"
    ]
  },
  "mcpServers": {
    "myserver": {
      "command": ".venv/Scripts/python.exe",
      "args": [
        "mock-mcp.py",
        "--port",
        "8080"
      ],
      "cwd": ".",
      "timeout": 15000
    },
    "sqlite_server": {
      "command": ".venv/Scripts/python.exe",
      "args": [
        "sqlite_mcp.py",
        "--port",
        "8081"
      ],
      "cwd": ".",
      "timeout": 15000
    },
    "playwright": {
      "command": "npx",
      "args": [
        "@playwright/mcp@latest"
      ],
      "cwd": ".",
      "timeout": 15000
    },
    "github": {
      "httpUrl": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer $GITHUB_MCP_PAT"
      },
      "cwd": ".",
      "timeout": 15000
    },
    "powershell": {
      "command": "node",
      "args": [
        "../psc-server.js"
      ],
      "cwd": "./psc",
      "timeout": 30000
    },
    "ssh-mcp": {
            "command": "npx",
            "args": [
                "ssh-mcp",
                "-y",
                "--",
                "--host=192.168.1.65",
                "--port=22",
                "--user=ibrez",
                "--password=robotics",
                //"--key=path/to/key",
                "--timeout=30000",
                "--maxChars=none"
            ]
    }
  },
  "tools": {
    "shell": {
      "enableInteractiveShell": true,
      "showColor": true,
      "pager": "less"
    }
  }
}